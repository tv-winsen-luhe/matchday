---
import logoSvg from '@/assets/logo.svg'
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>OG Image</title>
  </head>
  <body>
    <div class="og">
      <img src={logoSvg.src} alt="" width="220" height="220" class="og__logo" />
      <div class="og__main">
        <h1 class="og__title">
          <span>Match</span>
          <span class="og__title--outline">Day<span class="og__dot">.</span></span>
        </h1>
        <div class="og__date">
          <span class="og__date-day">04.07.</span>
          <span class="og__date-year">2026</span>
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    width: 1200px;
    height: 630px;
    overflow: hidden;
    margin: 0;
    padding: 0;
    font-family:
      system-ui,
      -apple-system,
      'Segoe UI',
      sans-serif;
  }

  .og {
    --ink: #0c1e3a;
    --paper: #f5f5f5;
    --volt: #ceff00;
    position: relative;
    width: 1200px;
    height: 630px;
    background: var(--paper);
    color: var(--ink);
    padding: 56px 64px;
    display: flex;
    flex-direction: column;
  }

  .og__logo {
    position: absolute;
    top: 56px;
    right: 64px;
    display: block;
  }

  .og__main {
    margin-top: auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .og__title {
    font-weight: 900;
    font-size: 200px;
    line-height: 0.82;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .og__title > span {
    display: block;
  }

  .og__title--outline {
    -webkit-text-stroke: 3px var(--ink);
    color: var(--paper);
    paint-order: stroke fill;
  }

  .og__dot {
    -webkit-text-stroke: 3px var(--volt);
    color: var(--volt);
  }

  .og__date {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    padding-bottom: 12px;
  }

  .og__date-day {
    font-weight: 900;
    font-size: 96px;
    line-height: 0.85;
    letter-spacing: -0.04em;
  }

  .og__date-year {
    font-weight: 900;
    font-size: 96px;
    line-height: 0.85;
    letter-spacing: -0.04em;
    -webkit-text-stroke: 2.5px var(--ink);
    color: var(--paper);
    paint-order: stroke fill;
  }
</style>
