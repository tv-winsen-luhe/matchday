---
import Layout from '@/layouts/default.astro'
import MarkerHighlight from '@/components/marker-highlight.astro'
import signetSvg from '@/assets/signet.svg'
import logoSvg from '@/assets/logo.svg'

const sectClass = 'sect border-t border-navy py-20 focus:outline-none md:py-[120px]'
const sectEyebrowClass = 'sect__eyebrow mb-6 block text-[11px] font-bold uppercase tracking-[0.2em] opacity-40'
const sectNoteClass = 'mb-14 max-w-[48ch] text-[15px] leading-[1.6] opacity-55'
const sectHeadlineClass =
  'sect__headline m-0 mb-8 text-[clamp(56px,10vw,120px)] font-black uppercase leading-[0.85] tracking-[-0.05em] [&>span]:block'
const catCardBaseClass =
  'cat-card stagger @container relative flex min-h-[420px] flex-col overflow-hidden bg-surface-alt p-7 text-navy'
const catCardClayClass =
  'cat-card cat-card--clay stagger @container relative flex min-h-[420px] flex-col overflow-hidden bg-clay p-7 text-white'
const catCardBadgeClass =
  'cat-card__badge self-start border-[1.5px] border-navy px-2.5 py-1 text-[11px] font-black uppercase tracking-[0.15em]'
const catCardBadgeInvClass =
  'cat-card__badge self-start border-[1.5px] border-white/40 px-2.5 py-1 text-[11px] font-black uppercase tracking-[0.15em] text-white'
const signupCardBaseClass = 'signup-card stagger @container flex min-h-[340px] flex-col bg-surface-alt p-7 text-navy'
const signupCardDarkClass =
  'signup-card signup-card--dark stagger @container flex min-h-[340px] flex-col bg-surface-dark p-7 text-white'
const signupBadgeClass =
  'signup-card__badge self-start border-[1.5px] border-navy px-2.5 py-1 text-[11px] font-black tracking-[0.15em]'
const signupBadgeInvClass =
  'signup-card__badge self-start border-[1.5px] border-white/40 px-2.5 py-1 text-[11px] font-black tracking-[0.15em] text-white'
---

<Layout
  title="Matchday Winsen 2026 — Tennis-Tagesturnier"
  description="Zwei Tennis-Matches gegen Gegner auf deinem Niveau — beide zählen für die LK. Neu dabei? Perfekt."
  ogTitle="Matchday Winsen 2026 — Tennis am 4. Juli"
  ogDescription="Zwei Tennis-Matches gegen Gegner auf deinem Niveau — beide zählen für die LK. Neu dabei? Perfekt."
  ogImage={`${import.meta.env.SITE}${import.meta.env.BASE_URL}/og-image.png`}
  bodyClass="bg-surface-alt"
>
  <main class="mx-auto max-w-[1280px] px-5 pt-6 pb-20 text-navy md:px-10 md:pt-8 md:pb-[120px]">
    <a
      href="#turniermodus"
      class="absolute -top-full left-4 z-[100] bg-neon px-5 py-2.5 text-[13px] font-extrabold tracking-[0.02em] text-navy uppercase no-underline focus-visible:top-4 focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-navy"
      >Direkt zum Inhalt</a
    >

    <!-- Topbar -->
    <header
      class="enter enter--1 flex flex-wrap items-baseline gap-3 border-b border-navy pb-4 text-[11px] font-semibold tracking-[0.18em] uppercase"
    >
      <img src={signetSvg.src} alt="TV Winsen/Luhe" width="24" height="24" class="shrink-0 self-center" />
      <span class="text-sm font-black tracking-[0.04em]">TV Winsen/Luhe</span>
      <span class="opacity-25">&middot;</span>
      <span class="text-[10px] opacity-45">Seit 1913</span>
      <span class="text-[10px] opacity-45">04. Juli 2026</span>
      <span class="text-[10px] opacity-45">6 Sandplätze</span>
      <span class="ml-auto text-[10px] opacity-45">LK-Tagesturnier</span>
    </header>

    <!-- Hero -->
    <section class="flex min-h-dvh flex-col justify-center pt-16 pb-[72px] md:pt-24 md:pb-[104px]">
      <div class="flex items-end justify-between gap-10 max-[600px]:flex-col max-[600px]:items-start max-[600px]:gap-8">
        <h1
          class="hero__title m-0 text-[clamp(72px,14vw,180px)] leading-[0.84] font-black tracking-[-0.05em] uppercase"
        >
          <span class="enter enter--2">Match</span>
          <span
            class="hero__title--outline enter enter--3 text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
            >Day<span class="inline text-neon text-stroke-volt max-md:[-webkit-text-stroke-width:1.5px]">.</span></span
          >
        </h1>
        <div class="enter enter--3 flex shrink-0 flex-col items-end max-[600px]:self-end">
          <span class="text-[11px] font-semibold tracking-[0.18em] uppercase opacity-40">Samstag</span>
          <span class="text-[clamp(48px,8vw,80px)] leading-[0.85] font-black tracking-[-0.04em]">04.07.</span>
          <span
            class="text-[clamp(48px,8vw,80px)] leading-[0.85] font-black tracking-[-0.04em] text-surface-alt text-stroke-ink-sm"
            >2026</span
          >
        </div>
      </div>

      <div class="mt-16 ml-auto max-w-[42ch] max-[600px]:ml-0">
        <p class="enter enter--4 m-0 text-[17px] leading-[1.55] font-medium">
          Neu dabei? Perfekt. Schon Erfahrung? Umso besser. Zwei Matches, beide zählen für deine LK.
        </p>
        <p class="enter enter--5 mt-3 text-[13px] leading-[1.55] opacity-35">
          Dieses Jahr starten wir mit Herren-Kategorien: Einzel, Doppel und Herren 40 Einzel.
        </p>

        <div class="enter enter--6 mt-8 flex flex-wrap items-center gap-6">
          <a href="#" class="cta-primary">Jetzt anmelden auf tennis.de</a>
          <a href="#turniermodus" class="cta-secondary">Mehr erfahren <span aria-hidden="true">&darr;</span></a>
        </div>
      </div>
    </section>

    <!-- Turniermodus -->
    <section id="turniermodus" class:list={[sectClass]} tabindex="-1">
      <span class:list={['reveal', sectEyebrowClass]}>So läuft dein Matchday</span>
      <h2 class={sectHeadlineClass}>
        <span class="sect__headline-clip" style="--i:0">Kein</span>
        <span
          class="sect__headline-clip text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
          style="--i:1">K.O.</span
        >
      </h2>
      <p class={sectNoteClass}>
        Zwei Matches gegen ähnlich starke Gegner — du spielst beide, egal wie das erste ausgeht.
      </p>

      <div class="flex items-start justify-between gap-16 max-md:flex-col max-md:gap-12">
        <div class="flex flex-col gap-12">
          <div class="reveal flex items-start gap-6">
            <span
              class="w-20 shrink-0 text-[72px] leading-[0.8] font-black tracking-[-0.04em] text-surface-alt text-stroke-ink-sm"
              >01</span
            >
            <div class="max-w-[48ch]">
              <h3 class="m-0 mb-2.5 text-[22px] font-extrabold tracking-[-0.02em]">Einteilung nach Spielstärke</h3>
              <p class="m-0 text-sm leading-[1.6] opacity-55">
                Alle Spieler werden vor dem Matchday nach Spielstärke sortiert. Dieses Verfahren heißt offiziell
                „Spiralsystem".
              </p>
            </div>
          </div>
          <div class="reveal flex items-start gap-6">
            <span
              class="w-20 shrink-0 text-[72px] leading-[0.8] font-black tracking-[-0.04em] text-surface-alt text-stroke-ink-sm"
              >02</span
            >
            <div class="max-w-[48ch]">
              <h3 class="m-0 mb-2.5 text-[22px] font-extrabold tracking-[-0.02em]">Zwei Matches</h3>
              <p class="m-0 text-sm leading-[1.6] opacity-55">
                Du spielst genau zwei Matches — einmal gegen jemanden mit etwas
                <span class="font-bold text-blue opacity-100">besserer LK</span> als du, und einmal gegen jemanden mit etwas
                <span class="font-bold text-clay opacity-100">schwächerer LK</span>. Beide Gegner sind nah an deinem
                Niveau.
              </p>
            </div>
          </div>
          <div class="reveal flex items-start gap-6">
            <span
              class="w-20 shrink-0 text-[72px] leading-[0.8] font-black tracking-[-0.04em] text-surface-alt text-stroke-ink-sm"
              >03</span
            >
            <div class="max-w-[48ch]">
              <h3 class="m-0 mb-2.5 text-[22px] font-extrabold tracking-[-0.02em]">Ergebnis</h3>
              <p class="m-0 text-sm leading-[1.6] opacity-55">
                Beide Matches fließen direkt in deine LK-Wertung ein. Kein Finale, keine Platzierung, kein Ausscheiden —
                es geht nur um deine Matches und deine LK.
              </p>
            </div>
          </div>
        </div>

        <figure
          class="spiral sticky top-10 m-0 w-[320px] shrink-0 max-md:static max-md:w-full max-md:max-w-[360px]"
          aria-hidden="true"
        >
          <figcaption class="mb-3 text-[10px] font-semibold tracking-[0.14em] uppercase opacity-35">
            Spielstärke ↓
          </figcaption>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5 last:border-b-0"
            style="--i:0"
          >
            <span class="text-[14px] font-semibold tracking-[-0.01em] opacity-25">LK 19.0</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5"
            style="--i:1"
          >
            <span class="text-[19px] font-extrabold tracking-[-0.01em] text-blue">LK 19.4</span>
            <span class="text-[10px] font-bold tracking-[0.1em] text-blue uppercase">Dein 1. Match</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5"
            style="--i:2"
          >
            <span class="text-[14px] font-semibold tracking-[-0.01em] opacity-25">LK 19.8</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-4"
            style="--i:3"
          >
            <span class="text-[26px] font-black tracking-[-0.03em]">LK 20.3</span>
            <span class="text-[10px] font-black tracking-[0.1em] uppercase">Du</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5"
            style="--i:4"
          >
            <span class="text-[14px] font-semibold tracking-[-0.01em] opacity-25">LK 20.7</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5"
            style="--i:5"
          >
            <span class="text-[19px] font-extrabold tracking-[-0.01em] text-clay">LK 21.1</span>
            <span class="text-[10px] font-bold tracking-[0.1em] text-clay uppercase">Dein 2. Match</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5"
            style="--i:6"
          >
            <span class="text-[14px] font-semibold tracking-[-0.01em] opacity-25">LK 21.6</span>
          </div>
          <div
            class="spiral-stagger spiral__row flex items-baseline justify-between gap-4 border-b border-navy/15 py-2.5 last:border-b-0"
            style="--i:7"
          >
            <span class="text-[14px] font-semibold tracking-[-0.01em] opacity-25">LK 22.0</span>
          </div>
        </figure>
      </div>
    </section>

    <!-- Mid-CTA -->
    <section class:list={[sectClass, 'py-[72px] md:py-[104px]']}>
      <div class="reveal flex items-end justify-between gap-12 max-md:flex-col max-md:items-start max-md:gap-8">
        <h2
          class="m-0 text-[clamp(48px,9vw,100px)] leading-[0.85] font-black tracking-[-0.05em] uppercase [&>span]:block"
        >
          <span>Klingt</span>
          <span class="text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]">gut?</span>
        </h2>
        <div class="max-w-[36ch] shrink-0">
          <a href="#" class="cta-primary">Jetzt anmelden auf tennis.de</a>
          <p class="mt-4 text-[13px] opacity-30">Oder lies weiter — Kategorien, Tagesablauf und FAQ kommen noch.</p>
        </div>
      </div>
    </section>

    <!-- Kategorien -->
    <section class:list={[sectClass]}>
      <h2 class:list={['reveal', sectEyebrowClass]}>Drei Kategorien</h2>

      <div class="cat-grid grid grid-cols-3 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-1">
        <!-- Einzel — Axis -->
        <div class={catCardBaseClass} style="--i:0">
          <span class={catCardBadgeClass}>Einzel</span>
          <div class="relative my-6 flex flex-1 flex-col">
            <span
              class="flex flex-1 items-center justify-center text-[clamp(48px,20cqw,110px)] leading-[0.85] font-black tracking-[-0.05em] uppercase"
              >Herren</span
            >
          </div>
          <div class="mt-auto pt-4 pl-5">
            <span class="mb-2 block text-2xl font-black tracking-[-0.03em]">35 €</span>
            <span class="block text-[10px] leading-[1.6] font-semibold tracking-[0.14em] uppercase opacity-45">
              Max. 10 Spieler · Alle Spielstärken
            </span>
          </div>
        </div>

        <!-- Doppel — Stack -->
        <div class={catCardBaseClass} style="--i:1">
          <span class={catCardBadgeClass}>Doppel</span>
          <div
            class="my-6 flex flex-1 flex-col justify-center [&>span]:border-b [&>span]:border-navy/15 [&>span]:py-1.5 [&>span]:text-[clamp(24px,8cqw,40px)] [&>span]:leading-none [&>span]:font-black [&>span]:tracking-[-0.035em] [&>span]:uppercase [&>span:last-child]:border-b-0"
          >
            <span>Herren</span>
            <span class="-mx-2 bg-neon px-2 text-navy">Doppel</span>
            <span>Herren</span>
            <span class="-mx-2 bg-neon px-2 text-navy">Doppel</span>
            <span>Herren</span>
          </div>
          <div class="mt-auto pt-4 pl-5">
            <span class="mb-2 block text-2xl font-black tracking-[-0.03em]">
              18 € <span class="text-xs font-medium tracking-[0.04em] opacity-50">pro Person</span>
            </span>
            <span class="block text-[10px] leading-[1.6] font-semibold tracking-[0.14em] uppercase opacity-45">
              Max. 8 Teams · Alle Spielstärken
            </span>
          </div>
        </div>

        <!-- Ü40 — Clay Axis -->
        <div class={catCardClayClass} style="--i:2">
          <span class={catCardBadgeInvClass}>Einzel</span>
          <div class="relative my-6 flex flex-1 flex-col">
            <span
              class="flex flex-1 items-center justify-center text-[clamp(48px,20cqw,110px)] leading-[0.85] font-black tracking-[-0.05em] uppercase"
              >Herren<br />40</span
            >
          </div>
          <div class="mt-auto pt-4 pl-5">
            <span class="mb-2 block text-2xl font-black tracking-[-0.03em]">35 €</span>
            <span class="block text-[10px] leading-[1.6] font-semibold tracking-[0.14em] text-white/85 uppercase">
              Max. 12 Spieler · Alle Spielstärken
            </span>
          </div>
        </div>
      </div>

      <p class="reveal mt-6 text-sm opacity-45">
        Die Teilnahmegebühr deckt alles ab: Organisation, Bälle und die offizielle Turniergebühr an den Verband.
      </p>
      <p class="reveal mt-3 text-sm font-semibold opacity-55">
        Nicht sicher, welche Kategorie? Die meisten starten mit Einzel — zwei Matches, ein klarer Tag.
      </p>
    </section>

    <!-- Tagesablauf -->
    <section class:list={[sectClass]}>
      <h2 class:list={['reveal', sectEyebrowClass]}>Dein Turniertag</h2>

      <p class={sectNoteClass}>
        Ein Tag, kompakt getaktet. Du kommst morgens oder mittags, spielst deine Matches, und bist im Regelfall am
        Nachmittag durch. Dazwischen: kurze Pausen, offene Gastronomie, und genug Zeit zum Zuschauen.
      </p>

      <div class="flex flex-col gap-4">
        <div
          class="reveal flex flex-wrap items-baseline justify-end gap-x-4 gap-y-3 max-[600px]:gap-x-2.5 max-[600px]:gap-y-2"
        >
          <span
            class="text-[clamp(32px,6vw,64px)] leading-[0.9] font-black tracking-[-0.04em] text-surface-alt uppercase text-stroke-ink-sm max-[600px]:text-[clamp(20px,5.5vw,32px)]"
            >09:00</span
          >
          <span
            class="text-[clamp(24px,4vw,48px)] leading-[0.9] font-light opacity-15 max-[600px]:text-[clamp(16px,4vw,24px)]"
            >&mdash;</span
          >
          <span
            class="text-[clamp(32px,6vw,64px)] leading-[0.9] font-medium tracking-[-0.04em] uppercase opacity-35 max-[600px]:text-[clamp(20px,5.5vw,32px)]"
            >Check-in</span
          >
          <span
            class="text-[clamp(24px,4vw,48px)] leading-[0.9] font-light opacity-15 max-[600px]:text-[clamp(16px,4vw,24px)]"
            >&mdash;</span
          >
          <span
            class="text-[clamp(32px,6vw,64px)] leading-[0.9] font-black tracking-[-0.04em] uppercase max-[600px]:text-[clamp(20px,5.5vw,32px)]"
            >Match</span
          >
        </div>
        <div
          class="reveal flex flex-wrap items-baseline justify-end gap-x-4 gap-y-3 pr-[clamp(48px,10vw,160px)] max-[600px]:gap-x-2.5 max-[600px]:gap-y-2 max-[600px]:pr-0"
          style="--reveal-delay: 0.15s"
        >
          <span
            class="text-[clamp(32px,6vw,64px)] leading-[0.9] font-black tracking-[-0.04em] uppercase opacity-[0.12] max-[600px]:text-[clamp(20px,5.5vw,32px)]"
            >Pause</span
          >
          <span
            class="text-[clamp(24px,4vw,48px)] leading-[0.9] font-light opacity-15 max-[600px]:text-[clamp(16px,4vw,24px)]"
            >&mdash;</span
          >
          <span
            class="text-[clamp(32px,6vw,64px)] leading-[0.9] font-black tracking-[-0.04em] uppercase max-[600px]:text-[clamp(20px,5.5vw,32px)]"
            >Match</span
          >
          <span
            class="text-[clamp(24px,4vw,48px)] leading-[0.9] font-light opacity-15 max-[600px]:text-[clamp(16px,4vw,24px)]"
            >&mdash;</span
          >
          <span
            class="text-[clamp(32px,6vw,64px)] leading-[0.9] font-black tracking-[-0.04em] uppercase max-[600px]:text-[clamp(20px,5.5vw,32px)]"
            ><MarkerHighlight brush={3}>Fertig</MarkerHighlight><span class="text-neon">.</span></span
          >
        </div>
      </div>

      <div class="mt-14 flex flex-col">
        <div
          class="reveal flex items-baseline gap-8 border-t border-b border-navy border-b-navy/15 py-7 last:border-b-navy max-md:gap-5 max-md:py-5"
        >
          <span
            class="w-[140px] shrink-0 text-[32px] leading-[0.9] font-black tracking-[-0.03em] text-surface-alt uppercase [-webkit-text-stroke:1px_var(--color-navy)] [paint-order:stroke_fill] max-md:w-[90px] max-md:text-2xl"
            >09:00</span
          >
          <div class="max-w-[44ch]">
            <h3 class="m-0 mb-1.5 text-lg font-extrabold tracking-[-0.02em]">Check-in</h3>
            <p class="m-0 text-sm leading-[1.55] opacity-45">
              Melde dich am Turniertisch. Du bekommst deinen Spielplan mit Gegner und Platz.
            </p>
          </div>
        </div>
        <div
          class="reveal flex items-baseline gap-8 border-b border-navy/15 py-7 max-md:gap-5 max-md:py-5"
          style="--reveal-delay: 0.08s"
        >
          <span
            class="w-[140px] shrink-0 text-[32px] leading-[0.9] font-black tracking-[-0.03em] text-surface-alt uppercase [-webkit-text-stroke:1px_var(--color-navy)] [paint-order:stroke_fill] max-md:w-[90px] max-md:text-2xl"
            >ab 09:30</span
          >
          <div class="max-w-[44ch]">
            <h3 class="m-0 mb-1.5 text-lg font-extrabold tracking-[-0.02em]">1. Match</h3>
            <p class="m-0 text-sm leading-[1.55] opacity-45">Einspielen (5–10 Min) mit deinem Gegner, dann Match.</p>
          </div>
        </div>
        <div
          class="reveal flex items-baseline gap-8 border-b border-navy/15 py-7 max-md:gap-5 max-md:py-5"
          style="--reveal-delay: 0.16s"
        >
          <span
            class="w-[140px] shrink-0 text-[32px] leading-[0.9] font-black tracking-[-0.03em] text-surface-alt uppercase [-webkit-text-stroke:1px_var(--color-navy)] [paint-order:stroke_fill] max-md:w-[90px] max-md:text-2xl"
            >~90 Min</span
          >
          <div class="max-w-[44ch]">
            <h3 class="m-0 mb-1.5 text-lg font-extrabold tracking-[-0.02em]">Pause</h3>
            <p class="m-0 text-sm leading-[1.55] opacity-45">Gastronomie im Clubhaus, zuschauen, entspannen.</p>
          </div>
        </div>
        <div
          class="reveal flex items-baseline gap-8 border-b border-navy/15 py-7 max-md:gap-5 max-md:py-5"
          style="--reveal-delay: 0.24s"
        >
          <span
            class="w-[140px] shrink-0 text-[32px] leading-[0.9] font-black tracking-[-0.03em] text-surface-alt uppercase [-webkit-text-stroke:1px_var(--color-navy)] [paint-order:stroke_fill] max-md:w-[90px] max-md:text-2xl"
            >danach</span
          >
          <div class="max-w-[44ch]">
            <h3 class="m-0 mb-1.5 text-lg font-extrabold tracking-[-0.02em]">2. Match</h3>
            <p class="m-0 text-sm leading-[1.55] opacity-45">
              Gegen deinen zweiten Gegner, ebenfalls nah an deinem Niveau.
            </p>
          </div>
        </div>
        <div
          class="reveal flex items-baseline gap-8 border-b border-navy py-7 max-md:gap-5 max-md:py-5"
          style="--reveal-delay: 0.32s"
        >
          <span
            class="w-[140px] shrink-0 text-[32px] leading-[0.9] font-black tracking-[-0.03em] text-surface-alt uppercase [-webkit-text-stroke:1px_var(--color-navy)] [paint-order:stroke_fill] max-md:w-[90px] max-md:text-2xl"
            >Done</span
          >
          <div class="max-w-[44ch]">
            <h3 class="m-0 mb-1.5 text-lg font-extrabold tracking-[-0.02em]">Fertig</h3>
            <p class="m-0 text-sm leading-[1.55] opacity-45">
              Ergebnisse fließen in deine LK, auf der Terrasse dein Bier.
            </p>
          </div>
        </div>
      </div>

      <p class="mt-12 max-w-[48ch] text-sm leading-[1.55] opacity-45">
        Der genaue Zeitplan hängt von der Teilnehmerzahl ab. Je nach Einteilung kann dein 1. Match auch erst mittags
        starten. Wer Einzel und Doppel spielt, sollte mit einem längeren Turniertag rechnen.
      </p>
    </section>

    <!-- Anmeldung -->
    <section class:list={[sectClass]}>
      <h2 class:list={['reveal', sectEyebrowClass]}>In 3 Schritten angemeldet</h2>

      <div class="signup-grid grid grid-cols-3 gap-0.5 bg-navy p-0.5 max-md:grid-cols-1">
        <div class={signupCardBaseClass} style="--i:0">
          <span class={signupBadgeClass}>1</span>
          <div class="my-6 flex flex-1 flex-col justify-center">
            <h3 class="m-0 mb-3 text-[clamp(20px,6cqw,28px)] leading-[1.1] font-black tracking-[-0.03em]">
              tennis.de-Account<br />anlegen
            </h3>
            <p class="m-0 text-[13px] leading-[1.55] opacity-50">Falls du noch keinen hast. Dauert 5 Minuten.</p>
          </div>
          <span class="mt-auto pt-4 text-[10px] font-semibold tracking-[0.14em] uppercase opacity-40">5 Min</span>
        </div>
        <div class={signupCardBaseClass} style="--i:1">
          <span class={signupBadgeClass}>2</span>
          <div class="my-6 flex flex-1 flex-col justify-center">
            <h3 class="m-0 mb-3 text-[clamp(20px,6cqw,28px)] leading-[1.1] font-black tracking-[-0.03em]">
              DTB-Lizenz<br />aktivieren
            </h3>
            <p class="m-0 text-[13px] leading-[1.55] opacity-50">
              Einmalig 20 €/Jahr, im Account buchbar. Eine Spielberechtigung für LK-Turniere — für Punktspiele brauchst
              du sie nicht. Für Doppel brauchen beide Spieler eine Lizenz.
            </p>
          </div>
          <span class="mt-auto pt-4 text-[10px] font-semibold tracking-[0.14em] uppercase opacity-40">20 €/Jahr</span>
        </div>
        <div class={signupCardDarkClass} style="--i:2">
          <span class={signupBadgeInvClass}>3</span>
          <div class="my-6 flex flex-1 flex-col justify-center">
            <h3 class="m-0 mb-3 text-[clamp(20px,6cqw,28px)] leading-[1.1] font-black tracking-[-0.03em]">
              Beim Matchday<br />anmelden
            </h3>
            <p class="m-0 text-[13px] leading-[1.55] opacity-40">
              Unser Direktlink führt dich zum richtigen Eintrag auf tennis.de. Die Anmeldeseite dort sieht anders aus
              als diese Seite — offiziell, formeller. Das ist normal.
            </p>
          </div>
          <a href="#" class="cta-primary">Jetzt anmelden</a>
        </div>
      </div>
    </section>

    <!-- Ort & Anfahrt -->
    <section class:list={[sectClass, 'sect--clay']}>
      <h2 class:list={['reveal', sectEyebrowClass]}>Ort & Anfahrt</h2>
      <div class="reveal mb-14">
        <span class="block text-[clamp(56px,10vw,120px)] leading-[0.85] font-black tracking-[-0.05em] uppercase"
          >6 Sand</span
        >
        <span
          class="venue__hero-sub block text-[clamp(56px,10vw,120px)] leading-[0.85] font-black tracking-[-0.05em] text-surface-alt uppercase text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
          >plätze<span class="inline text-neon text-stroke-volt max-md:[-webkit-text-stroke-width:1.5px]">.</span></span
        >
      </div>

      <div class="reveal flex items-start justify-between gap-16 max-md:flex-col max-md:gap-10">
        <div class="flex-1">
          <img src={logoSvg.src} alt="TV Winsen/Luhe von 1913 e.V." width="120" height="120" class="mb-5 block" />
          <address class="mb-5 text-[15px] not-italic opacity-80">Luhdorfer Str. 47a, 21423 Winsen (Luhe)</address>
          <p class="m-0 mb-1 text-sm leading-[1.55] opacity-80">Clubhaus mit Terrasse und Gastronomie</p>
          <p class="m-0 mb-1 text-sm leading-[1.55] opacity-80">
            Zuschauen ist jederzeit möglich — freie Sicht auf die Plätze.
          </p>
          <a
            href="https://maps.app.goo.gl/rndtuka3qNptRi2E7"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-block text-sm font-bold text-white underline underline-offset-[3px] transition-opacity duration-200 hover:opacity-60 focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-navy"
          >
            Route in Google Maps &nearr;
          </a>
        </div>

        <div class="w-[320px] shrink-0 max-md:w-full max-md:max-w-[360px]">
          <span class="mb-3 block text-[10px] font-semibold tracking-[0.14em] uppercase opacity-80"
            >So findest du uns</span
          >
          <div class="flex flex-col">
            <div class="flex items-baseline gap-5 border-b border-white/20 py-2.5">
              <span
                class="flex min-w-10 shrink-0 items-center justify-center text-[32px] leading-none font-black tracking-[-0.03em] text-clay [-webkit-text-stroke:1.5px_rgba(255,255,255,0.8)] [paint-order:stroke_fill]"
                >1</span
              >
              <span class="text-sm font-medium">Parke auf der Wiese des Schützenvereins</span>
            </div>
            <div class="flex items-baseline gap-5 border-b border-white/20 py-2.5">
              <span
                class="flex min-w-10 shrink-0 items-center justify-center text-[32px] leading-none font-black tracking-[-0.03em] text-clay [-webkit-text-stroke:1.5px_rgba(255,255,255,0.8)] [paint-order:stroke_fill]"
                >2</span
              >
              <span class="text-sm font-medium">Rechts am Schützenverein vorbei</span>
            </div>
            <div class="flex items-baseline gap-5 border-b border-white/20 py-2.5">
              <span
                class="flex min-w-10 shrink-0 items-center justify-center text-[32px] leading-none font-black tracking-[-0.03em] text-clay [-webkit-text-stroke:1.5px_rgba(255,255,255,0.8)] [paint-order:stroke_fill]"
                >3</span
              >
              <span class="text-sm font-medium">Dem Weg durch den Wald folgen (~2 Min)</span>
            </div>
            <div class="flex items-baseline gap-5 py-2.5">
              <span
                class="flex min-w-10 shrink-0 items-center justify-center text-[32px] leading-none font-black tracking-[-0.03em] text-clay [-webkit-text-stroke:1.5px_rgba(255,255,255,0.8)] [paint-order:stroke_fill]"
