---
/**
 * Visual explainer of the Spiralsystem — minimal editorial.
 * Vertical axis with small markers for players, angular
 * bracket connectors to match opponents.
 *
 * Colors driven by CSS custom properties:
 * --color-spiral-dot, --color-spiral-line-a, --color-spiral-line-b
 */
---

<div class="spiral-explainer" aria-hidden="true">
  <svg viewBox="0 0 420 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto w-full max-w-sm">
    <!-- Vertical axis -->
    <line x1="24" y1="16" x2="24" y2="384" stroke="var(--color-spiral-dot)" stroke-width="1" opacity="0.1"></line>

    <!-- Row 1: LK 19.0 -->
    <g class="row" style="--i:0">
      <rect x="18" y="13" width="12" height="3" fill="var(--color-spiral-dot)" opacity="0.15"></rect>
      <text x="42" y="19" class="label-lk">19.0</text>
    </g>

    <!-- Row 2: LK 19.4 — Match 1 -->
    <g class="row" style="--i:1">
      <rect x="14" y="63" width="20" height="4" fill="var(--color-spiral-line-a)"></rect>
      <text x="42" y="70" class="label-lk label-lk--a">19.4</text>
    </g>

    <!-- Row 3: LK 19.8 -->
    <g class="row" style="--i:2">
      <rect x="18" y="119" width="12" height="3" fill="var(--color-spiral-dot)" opacity="0.15"></rect>
      <text x="42" y="125" class="label-lk">19.8</text>
    </g>

    <!-- Row 4: DU — LK 20.3 -->
    <g class="row row--du" style="--i:3">
      <rect x="6" y="172" width="36" height="6" fill="var(--color-spiral-dot)"></rect>
      <text x="42" y="181" class="label-du">Du · 20.3</text>
    </g>

    <!-- Row 5: LK 20.7 -->
    <g class="row" style="--i:4">
      <rect x="18" y="231" width="12" height="3" fill="var(--color-spiral-dot)" opacity="0.15"></rect>
      <text x="42" y="237" class="label-lk">20.7</text>
    </g>

    <!-- Row 6: LK 21.1 — Match 2 -->
    <g class="row" style="--i:5">
      <rect x="14" y="285" width="20" height="4" fill="var(--color-spiral-line-b)"></rect>
      <text x="42" y="292" class="label-lk label-lk--b">21.1</text>
    </g>

    <!-- Row 7: LK 21.6 -->
    <g class="row" style="--i:6">
      <rect x="18" y="341" width="12" height="3" fill="var(--color-spiral-dot)" opacity="0.15"></rect>
      <text x="42" y="347" class="label-lk">21.6</text>
    </g>

    <!-- Row 8: LK 22.0 -->
    <g class="row" style="--i:7">
      <rect x="18" y="381" width="12" height="3" fill="var(--color-spiral-dot)" opacity="0.15"></rect>
      <text x="42" y="387" class="label-lk">22.0</text>
    </g>

    <!-- Connector: Match 1 -->
    <path
      d="M 42 175 L 160 175 L 160 65 L 42 65"
      stroke="var(--color-spiral-line-a)"
      stroke-width="1"
      fill="none"
      class="connector"
      style="--i:0; --len:338"></path>

    <!-- Connector: Match 2 -->
    <path
      d="M 42 175 L 200 175 L 200 287 L 42 287"
      stroke="var(--color-spiral-line-b)"
      stroke-width="1"
      fill="none"
      class="connector"
      style="--i:1; --len:428"></path>

    <!-- Match 1 label -->
    <g class="match-label" style="--i:0">
      <text x="168" y="116" class="label-match" fill="var(--color-spiral-line-a)">Match 1</text>
      <text x="168" y="130" class="label-desc">bessere LK</text>
    </g>

    <!-- Match 2 label -->
    <g class="match-label" style="--i:1">
      <text x="208" y="227" class="label-match" fill="var(--color-spiral-line-b)">Match 2</text>
      <text x="208" y="241" class="label-desc">schlechtere LK</text>
    </g>

    <!-- Top annotation -->
    <text x="420" y="19" text-anchor="end" class="label-bracket row" style="--i:0">Spielstärke ↓</text>
  </svg>
</div>

<style>
  .spiral-explainer {
    --dur: 0.4s;
    --delay-base: 0.08s;
  }

  .label-lk {
    font-size: 12px;
    font-weight: 600;
    fill: var(--color-spiral-dot);
    opacity: 0.25;
  }
  .label-lk--a {
    fill: var(--color-spiral-line-a);
    opacity: 0.8;
  }
  .label-lk--b {
    fill: var(--color-spiral-line-b);
    opacity: 0.8;
  }
  .label-du {
    font-size: 14px;
    font-weight: 900;
    fill: var(--color-spiral-dot);
    letter-spacing: 0.04em;
  }
  .label-bracket {
    font-size: 10px;
    font-weight: 600;
    fill: var(--color-spiral-dot);
    opacity: 0.25;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .label-match {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .label-desc {
    font-size: 10px;
    font-weight: 500;
    fill: var(--color-spiral-dot);
    opacity: 0.35;
  }

  .row {
    opacity: 0;
    animation: fadeIn var(--dur) ease-out forwards;
    animation-delay: calc(var(--i) * var(--delay-base));
  }

  .connector {
    stroke-dasharray: var(--len);
    stroke-dashoffset: var(--len);
    animation: drawLine 0.7s ease-in-out forwards;
    animation-delay: calc(0.7s + var(--i) * 0.3s);
  }

  .match-label {
    opacity: 0;
    animation: fadeIn 0.3s ease-out forwards;
    animation-delay: calc(1.1s + var(--i) * 0.3s);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes drawLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  .spiral-explainer:not(.is-visible) * {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .row,
    .match-label {
      opacity: 1;
      animation: none;
    }
    .connector {
      stroke-dashoffset: 0;
      animation: none;
    }
    .spiral-explainer:not(.is-visible) * {
      animation-play-state: running;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const el = document.querySelector('.spiral-explainer')

  if (el) {
    if (prefersReducedMotion) {
      el.classList.add('is-visible')
    } else {
      const obs = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            el.classList.add('is-visible')
            obs.disconnect()
          }
        },
        { threshold: 0.3 }
      )
      obs.observe(el)
    }
  }
</script>
