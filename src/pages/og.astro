---
import '../styles/global.css'
import logoSvg from '@/assets/logo.svg'
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>OG Image</title>
  </head>
  <body class="h-[630px] w-[1200px] overflow-hidden">
    <div class="relative flex h-[630px] w-[1200px] flex-col bg-surface-alt px-16 py-14 text-navy">
      <img src={logoSvg.src} alt="" width="220" height="220" class="absolute top-14 right-16 block" />
      <div class="mt-auto flex items-end justify-between gap-10">
        <h1 class="text-[200px] leading-[0.82] font-black tracking-[-0.05em] uppercase">
          <span class="block">Match</span>
          <span class="block text-surface-alt [-webkit-text-stroke:3px_var(--color-navy)] [paint-order:stroke_fill]">
            Day<span class="text-neon [-webkit-text-stroke:3px_var(--color-neon)]">.</span>
          </span>
        </h1>
        <div class="flex shrink-0 flex-col items-end pb-3">
          <span class="text-[96px] leading-[0.85] font-black tracking-[-0.04em]">04.07.</span>
          <span
            class="text-[96px] leading-[0.85] font-black tracking-[-0.04em] text-surface-alt [-webkit-text-stroke:2.5px_var(--color-navy)] [paint-order:stroke_fill]"
            >2026</span
          >
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  html,
  body {
    font-family:
      system-ui,
      -apple-system,
      'Segoe UI',
      sans-serif;
  }
</style>
