---
import Layout from '@/layouts/default.astro'
import MarkerHighlight from '@/components/marker-highlight.astro'
import Card from '@/components/card.astro'
import logoSvg from '@/assets/logo.svg'
import signetSvg from '@/assets/signet.svg'

const colorScales = [
  {
    name: 'Navy',
    role: 'Vereinsfarbe · Primär',
    shades: [
      { step: 'Light', value: '#8b9bb1', dark: false },
      { step: 'Base', value: '#0c1e3a', dark: true }
    ]
  },
  {
    name: 'Blue',
    role: 'Vereinsakzent · Sekundär',
    shades: [
      { step: 'Light', value: '#c7e8fe', dark: false },
      { step: 'Base', value: '#199cf9', dark: false }
    ]
  },
  {
    name: 'Neon',
    role: 'Event-Highlight · Akzent',
    shades: [
      { step: 'Light', value: '#edff80', dark: false },
      { step: 'Base', value: '#ceff00', dark: false }
    ]
  },
  {
    name: 'Clay',
    role: 'Sandplatz · Terre Battue',
    shades: [
      { step: 'Light', value: '#E8C9B0', dark: false },
      { step: 'Base', value: '#C2673B', dark: true }
    ]
  },
  {
    name: 'Gray',
    role: 'Neutral · System',
    shades: [
      { step: 'Light', value: '#f5f5f5', dark: false },
      { step: 'Base', value: '#737373', dark: true }
    ]
  }
]

const semanticColors = [
  { name: 'surface', value: '#ffffff', label: 'Hintergrund' },
  { name: 'surface-alt', value: '#f5f5f5', label: 'Alt. Hintergrund' },
  { name: 'surface-dark', value: '#060d18', label: 'Dunkler Grund' },
  { name: 'surface-warm', value: '#E8C9B0', label: 'Warmer Grund' },
  { name: 'text', value: '#0c1e3a', label: 'Textfarbe' },
  { name: 'text-muted', value: '#525252', label: 'Sekundärtext' },
  { name: 'text-inverted', value: '#ffffff', label: 'Invertiert' },
  { name: 'border', value: '#e5e5e5', label: 'Rahmen' },
  { name: 'border-strong', value: '#d4d4d4', label: 'Starker Rahmen' },
  { name: 'ring', value: '#199cf9', label: 'Fokus' }
]

const fontWeights = [
  { name: 'Light', value: '300', class: 'font-light' },
  { name: 'Regular', value: '400', class: 'font-normal' },
  { name: 'Medium', value: '500', class: 'font-medium' },
  { name: 'Semibold', value: '600', class: 'font-semibold' },
  { name: 'Bold', value: '700', class: 'font-bold' },
  { name: 'Extra Bold', value: '800', class: 'font-extrabold' },
  { name: 'Black', value: '900', class: 'font-black' }
]

const brushExamples = [3, 5] as const

const sectClass = 'sect border-t border-navy py-[72px]'
const sectLabelClass = 'mb-3 block text-[11px] font-bold uppercase tracking-[0.2em]'
const sectNoteClass = 'mb-10 max-w-[56ch] text-[13px] leading-[1.6] opacity-60'
const cellTagClass = 'mb-4 block text-[10px] font-semibold uppercase tracking-[0.18em] opacity-50'
const cellTagInvClass = 'mb-4 block text-[10px] font-semibold uppercase tracking-[0.18em] text-white opacity-30'
const compCardNumClass = 'self-start border-[1.5px] border-navy px-[9px] py-1 text-xs font-black tracking-[0.15em]'
const compCardDescClass = 'mt-auto pt-4 text-[10px] font-semibold uppercase tracking-[0.14em] opacity-45'
---

<Layout title="Brand Guide – Matchday Winsen 2026" bodyClass="bg-surface-alt">
  <main class="mx-auto max-w-[1280px] px-5 pt-6 pb-20 text-navy md:px-10 md:pt-8 md:pb-[120px]">
    <!-- Topbar -->
    <header
      class="flex flex-wrap items-baseline gap-3 border-b border-navy pb-4 text-[11px] font-semibold tracking-[0.18em] uppercase"
    >
      <span class="text-sm font-black tracking-[0.04em]">Brand Guide</span>
      <span class="opacity-25">·</span>
      <span class="text-[10px] opacity-45">Matchday Winsen 2026</span>
      <span class="text-[10px] opacity-45">TV Winsen/Luhe</span>
      <span class="ml-auto text-[10px] opacity-45">Design-System</span>
    </header>

    <!-- Hero -->
    <section class="px-0 pt-16 pb-[72px] md:pt-24 md:pb-[104px]">
      <div
        class="enter enter--1 mb-12 flex gap-8 border-b border-navy pb-3 text-[11px] font-semibold tracking-[0.18em] uppercase max-[600px]:flex-wrap max-[600px]:gap-x-6 max-[600px]:gap-y-2 [&>span+span]:opacity-40"
      >
        <span>Matchday Winsen</span>
        <span>TV Winsen/Luhe</span>
        <span>2026</span>
      </div>
      <h1 class="m-0 text-display leading-[0.84] font-black tracking-[-0.05em] uppercase">
        <span class="enter enter--2 block">Brand</span>
        <span
          class="enter enter--3 block text-transparent [-webkit-text-stroke:1.5px_var(--color-navy)] md:[-webkit-text-stroke-width:2px]"
          >Guide</span
        >
      </h1>
      <p
        class="enter enter--4 mt-16 ml-auto max-w-[48ch] text-[15px] leading-[1.6] opacity-65 [&>strong]:font-bold [&>strong]:opacity-100"
      >
        Visuelle Richtlinien für das Matchday Winsen 2026 Turnier. Farben, Typografie, Logos und Komponenten —
        sportlich-energisch trifft <strong>modern-minimal</strong>.
      </p>
    </section>

    <!-- 01 Logos -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>01 — Logos</span>
      <p class={sectNoteClass}>Signet und vollständiges Logo — auf hellem und dunklem Grund.</p>

      <div class="grid grid-cols-2 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-1">
        <div class="flex min-h-[240px] flex-col bg-white p-8">
          <span class={cellTagClass}>Hell</span>
          <div class="mt-6 flex flex-1 items-end gap-8">
            <figure class="shrink-0">
              <img src={signetSvg.src} alt="Signet" width="64" height="64" />
              <figcaption class="mt-2 text-[10px] font-semibold tracking-[0.14em] uppercase opacity-45">
                Signet
              </figcaption>
            </figure>
            <figure class="shrink-0">
              <img src={logoSvg.src} alt="Logo" width="160" height="160" />
              <figcaption class="mt-2 text-[10px] font-semibold tracking-[0.14em] uppercase opacity-45">
                Logo
              </figcaption>
            </figure>
          </div>
        </div>
        <div class="flex min-h-[240px] flex-col bg-navy p-8">
          <span class={cellTagInvClass}>Dunkel</span>
          <div class="mt-6 flex flex-1 items-end gap-8">
            <figure class="shrink-0">
              <img src={signetSvg.src} alt="Signet" width="64" height="64" />
              <figcaption class="mt-2 text-[10px] font-semibold tracking-[0.14em] text-white/30 uppercase">
                Signet
              </figcaption>
            </figure>
            <figure class="shrink-0">
              <img src={logoSvg.src} alt="Logo" width="160" height="160" />
              <figcaption class="mt-2 text-[10px] font-semibold tracking-[0.14em] text-white/30 uppercase">
                Logo
              </figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- 02 Farbpalette -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>02 — Farbpalette</span>
      <p class={sectNoteClass}>Vier Skalen — je drei Stufen. Hierarchie entsteht über Gewicht, nicht über Menge.</p>

      {
        colorScales.map(scale => (
          <div class="mb-8 last:mb-0">
            <div class="mb-2 flex items-baseline gap-3">
              <span class="text-base font-black tracking-[-0.01em]">{scale.name}</span>
              <span class="text-[10px] font-semibold tracking-[0.14em] uppercase opacity-40">{scale.role}</span>
            </div>
            <div class="grid grid-cols-2 gap-0.5 bg-navy p-0.5">
              {scale.shades.map(shade => (
                <div
                  class="flex aspect-5/3 flex-col justify-end gap-1 p-5 max-[600px]:aspect-3/1"
                  style={`background-color: ${shade.value}`}
                >
                  <span class:list={['text-lg font-black tracking-[-0.01em]', shade.dark ? 'text-white' : 'text-navy']}>
                    {shade.value}
                  </span>
                  <span
                    class:list={[
                      'text-[10px] font-semibold tracking-[0.18em] uppercase',
                      shade.dark ? 'text-white/50' : 'text-navy/50'
                    ]}
                  >
                    {shade.step}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <!-- 03 Semantische Farben -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>03 — Semantische Farben</span>
      <p class={sectNoteClass}>Zweckgebundene Aliase für konsistente Anwendung.</p>

      <div class="grid grid-cols-3 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        {
          semanticColors.map(color => (
            <div class="flex items-center gap-3 bg-surface-alt px-5 py-4">
              <div
                class:list={['h-7 w-7 shrink-0 rounded', color.value === '#ffffff' && 'border border-navy/15']}
                style={`background-color: ${color.value}`}
              />
              <div class="min-w-0 flex-1">
                <span class="block text-[13px] font-bold">{color.name}</span>
                <span class="mt-px block text-[10px] font-semibold tracking-[0.12em] uppercase opacity-40">
                  {color.label}
                </span>
              </div>
              <code class="shrink-0 font-mono text-[10px] opacity-40">{color.value}</code>
            </div>
          ))
        }
      </div>
    </section>

    <!-- 04 Typografie -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>04 — Typografie</span>
      <p class={sectNoteClass}>
        System-Schriftarten: <code class="font-mono text-[11px]">ui-sans-serif, system-ui, sans-serif</code>. Die
        Typografie trägt die Komposition allein — Hierarchie über Größe und Gewicht.
      </p>

      <div class="border-t border-navy/15 py-7 first-of-type:border-t-0 first-of-type:pt-0">
        <span class={cellTagClass}>Display — Black 900</span>
        <div class="text-[clamp(64px,12vw,160px)] leading-[0.85] font-black tracking-[-0.05em]">Matchday.</div>
      </div>

      <div class="border-t border-navy/15 py-7">
        <span class={cellTagClass}>Outline-Regel</span>
        <div class="text-[clamp(48px,8vw,96px)] leading-[0.85] font-black tracking-[-0.05em] uppercase">
          <span>Match</span><span class="text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
            >Day.</span
          >
        </div>
        <p class="mt-5 max-w-[56ch] text-[13px] leading-[1.6] opacity-60">
          Das zweite Wort der Headline bekommt Kontur statt Füllung. Utilities:
          <code class="font-mono text-[11px]">text-stroke-ink</code> (Navy) auf hellem Grund,
          <code class="font-mono text-[11px]">text-stroke-volt</code> (Neon) als Akzent-Stroke. Auf Clay kippt der Stroke
          auf Weiß. Stroke-Breite: 2px Desktop, 1.5px Mobile (<code class="font-mono text-[11px]"
            >max-md:[-webkit-text-stroke-width:1.5px]</code
          >).
        </p>
      </div>

      <div class="border-t border-navy/15 py-7">
        <span class={cellTagClass}>Tennisball-Punkt</span>
        <div class="text-[clamp(48px,8vw,96px)] leading-[0.85] font-black tracking-[-0.05em] uppercase">
          Matchday<span class="inline text-neon text-stroke-volt max-md:[-webkit-text-stroke-width:1.5px]">.</span>
        </div>
        <p class="mt-5 max-w-[56ch] text-[13px] leading-[1.6] opacity-60">
          Der abschließende Satzpunkt einer Display-Headline wird zum Tennisball: Neon-Füllung plus Neon-Stroke skaliert
          mit der Schrift. Nur als terminierender Akzent, nie mitten im Satz. Aktuell auf index.astro im Hero
          („Matchday.") und im Venue-Hero („Sandplätze.").
        </p>
      </div>

      <div class="border-t border-navy/15 py-7">
        <span class={cellTagClass}>Outline-Zahlen</span>
        <div class="mt-4 grid grid-cols-3 gap-4 max-[900px]:grid-cols-1">
          <div class="flex flex-col gap-3">
            <span class="text-[48px] leading-none font-black tracking-[-0.04em] text-surface-alt text-stroke-ink-sm"
              >04.07.</span
            >
            <span class="text-[9px] font-semibold tracking-[0.14em] uppercase opacity-45"
              >Display · stroke-ink-sm (1.5px)</span
            >
          </div>
          <div class="flex flex-col gap-3">
            <span
              class="text-[32px] leading-none font-black tracking-[-0.03em] text-surface-alt uppercase [-webkit-text-stroke:1px_var(--color-navy)] [paint-order:stroke_fill]"
              >09:00</span
            >
            <span class="text-[9px] font-semibold tracking-[0.14em] uppercase opacity-45">Timeline · 1px Navy</span>
          </div>
          <div class="flex flex-col gap-3 bg-clay px-4 py-3">
            <span
              class="text-[32px] leading-none font-black tracking-[-0.03em] text-clay [-webkit-text-stroke:1.5px_rgba(255,255,255,0.8)] [paint-order:stroke_fill]"
              >1</span
            >
            <span class="text-[9px] font-semibold tracking-[0.14em] text-white/70 uppercase">Clay · 1.5px Weiß</span>
          </div>
        </div>
        <p class="mt-5 max-w-[56ch] text-[13px] leading-[1.6] opacity-60">
          Zahlen übernehmen die Outline-Regel in drei Skalen. Display (Datum im Hero, Schritt-Nummern 01/02/03):
          <code class="font-mono text-[11px]">text-stroke-ink-sm</code>. Timeline (Uhrzeiten, 32px): inline
          <code class="font-mono text-[11px]">[-webkit-text-stroke:1px_var(--color-navy)]</code>. Auf Clay kehrt sich
          das um — Füllung Clay, Stroke Weiß in 1.5px.
        </p>
      </div>

      <div class="border-t border-navy/15 py-7">
        <span class={cellTagClass}>Headline — Extra Bold 800</span>
        <div class="text-[clamp(36px,6vw,80px)] leading-[0.95] font-extrabold tracking-[-0.035em]">
          Willkommen zum<br />Matchday Winsen.
        </div>
      </div>

      <div class="border-t border-navy/15 py-7">
        <span class={cellTagClass}>Body — Regular 400</span>
        <p class="m-0 max-w-[58ch] text-base leading-[1.6] opacity-75">
          Das LK-Tagesturnier des TV Winsen bringt Spielerinnen und Spieler aller Leistungsklassen zusammen. Ein Tag,
          ein Turnier, maximaler Wettkampf. Anmeldung über die Website des Vereins.
        </p>
      </div>

      <div class="mt-7 border-t border-navy/15 pt-9 pb-10">
        <span class={cellTagClass}>Schriftschnitte</span>
        <div class="grid grid-cols-7 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-4 max-[600px]:grid-cols-3">
          {
            fontWeights.map(weight => (
              <div class="flex min-h-[120px] flex-col items-center justify-between gap-3 bg-surface-alt px-4 py-5">
                <span
                  class:list={[weight.class, 'text-[clamp(36px,4vw,56px)] leading-none tracking-[-0.03em] text-navy']}
                >
                  Ag
                </span>
                <div class="text-center">
                  <span class="block font-mono text-[10px] opacity-50">{weight.value}</span>
                  <span class="mt-0.5 block text-[9px] font-semibold tracking-[0.14em] uppercase opacity-35">
                    {weight.name}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Heading-Styles -->
      <div class="mt-10 bg-navy px-7 pt-7 pb-9 md:px-10 md:pt-10 md:pb-12">
        <span class={cellTagInvClass}>Heading-Styles · Dunkel</span>
        <div class="mt-6 flex flex-col gap-7">
          <div>
            <span class="text-[10px] font-semibold tracking-[0.18em] text-white uppercase opacity-20">H1</span>
            <p
              class="mt-1 mb-0 text-[clamp(40px,8vw,96px)] leading-[0.88] font-extrabold tracking-[-0.045em] text-white"
            >
              Matchday Winsen
            </p>
          </div>
          <div>
            <span class="text-[10px] font-semibold tracking-[0.18em] text-white uppercase opacity-20">H2</span>
            <p class="mt-1 mb-0 text-[clamp(24px,4vw,48px)] leading-none font-bold tracking-[-0.03em] text-white">
              Turnierübersicht
            </p>
          </div>
          <div>
            <span class="text-[10px] font-semibold tracking-[0.18em] text-white uppercase opacity-20">H3</span>
            <p class="mt-1 mb-0 text-[clamp(18px,2vw,24px)] font-semibold text-white">Spielgruppe A</p>
          </div>
          <div>
            <span class="text-[10px] font-semibold tracking-[0.18em] text-white uppercase opacity-20">Body</span>
            <p class="mt-1 mb-0 max-w-[52ch] text-[15px] leading-[1.55] text-white/45">
              Das LK-Tagesturnier des TV Winsen bringt Spielerinnen und Spieler aller Leistungsklassen zusammen.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 05 Komposition -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>05 — Komposition</span>
      <p class={sectNoteClass}>
        Drei Graphic Devices — alle rein typografisch. Keine Illustration, kein Court-Motiv. Die Anordnung selbst trägt
        die Botschaft.
      </p>

      <div class="grid grid-cols-4 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        <Card variant="light" minHeight={380} class="stagger--1">
          <span class={compCardNumClass}>A</span>
          <div class="relative my-6 flex-1">
            <span
              class="absolute top-1/2 left-2 origin-[left_center] -rotate-90 text-xs font-bold tracking-[0.22em] whitespace-nowrap uppercase"
              >Seit 1913</span
            >
            <span
              class="absolute top-1/2 right-0 left-12 -translate-y-1/2 text-[clamp(28px,8cqw,44px)] leading-[0.9] font-black tracking-[-0.035em] uppercase"
              >Matchday<br />Winsen</span
            >
          </div>
          <span class={compCardDescClass}>Vertikale Achse trifft horizontale Headline</span>
        </Card>

        <Card variant="light" minHeight={380} class="stagger--2">
          <span class={compCardNumClass}>B</span>
          <div
            class="my-6 flex flex-1 flex-col justify-center [&>span]:border-b [&>span]:border-navy/15 [&>span]:py-1.5 [&>span]:text-[clamp(28px,8cqw,44px)] [&>span]:leading-none [&>span]:font-black [&>span]:tracking-[-0.035em] [&>span]:uppercase [&>span:last-child]:border-b-0"
          >
            <span>Matchday</span>
            <span>Matchday</span>
            <span class="-mx-2 bg-neon px-2 text-navy">Matchday</span>
            <span>Matchday</span>
            <span>Matchday</span>
          </div>
          <span class={compCardDescClass}>Wiederholung — Volt bricht das Muster</span>
        </Card>

        <Card variant="light" minHeight={380} class="stagger--3">
          <span class={compCardNumClass}>C</span>
          <div
            class="my-6 flex flex-1 items-center justify-center text-[clamp(72px,32cqw,140px)] leading-[0.8] font-black tracking-[-0.05em]"
          >
            2026
          </div>
          <span class={compCardDescClass}>Ziffer als eigenständiges Motiv</span>
        </Card>

        <Card variant="clay" minHeight={380} class="stagger--4">
          <span
            class="self-start border-[1.5px] border-white/40 px-[9px] py-1 text-xs font-black tracking-[0.15em] text-white"
            >D</span
          >
          <div class="my-6 flex flex-1 flex-col justify-center">
            <span class="mb-2 text-[10px] font-semibold tracking-[0.2em] uppercase opacity-50">Terre Battue</span>
            <span class="text-[clamp(32px,10cqw,52px)] leading-[0.9] font-black tracking-[-0.04em] uppercase">
              Sandplatz
            </span>
          </div>
          <span class="mt-auto pt-4 text-[10px] font-semibold tracking-[0.14em] text-white/50 uppercase">
            Warme Fläche als Kontrast zu Navy + Neon
          </span>
        </Card>
      </div>
    </section>

    <!-- 06 Marker Highlight -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>06 — Marker Highlight</span>
      <p class={sectNoteClass}>Texthervorhebung mit handgezeichneten Brush-Strokes. Volt-Akzent auf hellem Grund.</p>

      <div class="mb-10">
        {
          brushExamples.map(brush => (
            <div class="flex items-center gap-5 border-b border-navy/15 py-[14px] last:border-b-0">
              <code class="w-5 shrink-0 text-right font-mono text-[11px] opacity-35">{brush}</code>
              <p class="m-0 text-[clamp(36px,5vw,56px)] leading-[1.1] font-extrabold tracking-[-0.03em] text-navy">
                <MarkerHighlight brush={brush}>Matchday 2026</MarkerHighlight>
              </p>
            </div>
          ))
        }
      </div>

      <div class="border-2 border-navy bg-surface-alt px-6 py-8 md:px-11 md:py-12">
        <p class="m-0 text-[clamp(32px,6vw,72px)] leading-[0.92] font-extrabold tracking-[-0.04em] text-navy">
          Willkommen zum<br />
          <MarkerHighlight>Matchday</MarkerHighlight>
        </p>
        <p class="mt-5 text-[17px] text-navy opacity-65">
          Das <MarkerHighlight brush={3}>LK-Tagesturnier</MarkerHighlight> in Winsen an der Luhe.
        </p>
      </div>
    </section>

    <!-- 07 Motion -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>07 — Motion</span>
      <p class={sectNoteClass}>
        Vier Animation-Primitives. Bewegung trägt die Hierarchie, nie Dekoration. Timing-Kurve durchgehend <code
          class="font-mono text-[11px]">cubic-bezier(0.16, 1, 0.3, 1)</code
        >. Alle Primitives respektieren <code class="font-mono text-[11px]">prefers-reduced-motion</code>.
      </p>

      <div class="grid grid-cols-2 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-1">
        <Card variant="light" minHeight={240} class="stagger--1">
          <span class={compCardNumClass}>Enter</span>
          <div class="my-6 flex-1">
            <p class="m-0 text-lg font-extrabold tracking-[-0.02em]">Hero-Intro</p>
            <p class="mt-2 text-[13px] leading-[1.55] opacity-60">
              Einmalige Fade+Rise-Sequenz beim Seiten-Laden. Staffelung über
              <code class="font-mono text-[11px]">.enter--1</code> bis <code class="font-mono text-[11px]">--6</code> mit
              Delays 0.1s – 0.85s. Nur für Above-the-fold.
            </p>
          </div>
          <code class="mt-auto block font-mono text-[10px] opacity-50">class="enter enter--2"</code>
        </Card>

        <Card variant="light" minHeight={240} class="stagger--2">
          <span class={compCardNumClass}>Reveal</span>
          <div class="my-6 flex-1">
            <p class="m-0 text-lg font-extrabold tracking-[-0.02em]">Scroll-Intro</p>
            <p class="mt-2 text-[13px] leading-[1.55] opacity-60">
              Fade+Rise beim Eintritt ins Viewport. Dauer 0.7s. Trigger via IntersectionObserver (<code
                class="font-mono text-[11px]">.reveal.is-visible</code
              >) oder
              <code class="font-mono text-[11px]">animation-timeline: view()</code>.
            </p>
          </div>
          <code class="mt-auto block font-mono text-[10px] opacity-50">class="reveal"</code>
        </Card>

        <Card variant="light" minHeight={240} class="stagger--3">
          <span class={compCardNumClass}>Stagger</span>
          <div class="my-6 flex-1">
            <p class="m-0 text-lg font-extrabold tracking-[-0.02em]">Grid-Choreografie</p>
            <p class="mt-2 text-[13px] leading-[1.55] opacity-60">
              Reveal mit indexbasierter Verzögerung. Schrittweite 0.08s über Custom-Property
              <code class="font-mono text-[11px]">--i</code>. Karten erscheinen versetzt — diese vier Karten sind selbst
              das Beispiel.
            </p>
          </div>
          <code class="mt-auto block font-mono text-[10px] opacity-50">class="stagger" style="--i: 0"</code>
        </Card>

        <Card variant="light" minHeight={240} class="stagger--4">
          <span class={compCardNumClass}>Headline-Clip</span>
          <div class="my-6 flex-1">
            <p class="m-0 text-lg font-extrabold tracking-[-0.02em]">Outline-Reveal</p>
            <p class="mt-2 text-[13px] leading-[1.55] opacity-60">
              Clip-Path-Enthüllung für Display-Headlines. Zweite Zeile (mit Outline) startet 0.12s nach der ersten.
              Triggert über <code class="font-mono text-[11px]">.sect.is-visible</code>.
            </p>
          </div>
          <code class="mt-auto block font-mono text-[10px] opacity-50">class="sect__headline-clip" style="--i: 1"</code>
        </Card>
      </div>
    </section>

    <!-- 08 Section-Patterns -->
    <section class:list={['reveal', sectClass]}>
      <span class={sectLabelClass}>08 — Section-Patterns</span>
      <p class={sectNoteClass}>
        Zwei Section-Varianten. Standard begrenzt auf
        <code class="font-mono text-[11px]">max-w-[1280px]</code>, Full-Bleed bricht aus dem Grid aus für Farb-Zäsuren.
      </p>

      <div class="mb-8 border-t border-navy/15 py-7 first-of-type:border-t-0 first-of-type:pt-0">
        <span class={cellTagClass}>Standard</span>
        <div class="relative mt-4 overflow-hidden border border-navy/15 bg-surface-alt px-6 py-8">
          <span class="absolute inset-x-0 top-0 h-px bg-navy"></span>
          <span class="block text-[10px] font-bold tracking-[0.2em] uppercase opacity-40">Sektion</span>
          <p class="mt-4 text-[clamp(24px,4vw,40px)] leading-[0.9] font-black tracking-[-0.035em]">Im Raster</p>
        </div>
        <p class="mt-3 max-w-[56ch] text-[13px] leading-[1.6] opacity-60">
          <code class="font-mono text-[11px]">border-t border-navy</code>,
          <code class="font-mono text-[11px]">py-20 md:py-[120px]</code>, innerhalb
          <code class="font-mono text-[11px]">max-w-[1280px]</code>. Default für alle Content-Sektionen.
        </p>
      </div>

      <div class="border-t border-navy/15 py-7">
        <span class={cellTagClass}>Full-Bleed Clay</span>
        <div class="relative mt-4 overflow-hidden bg-clay px-6 py-8 text-white">
          <span class="block text-[10px] font-bold tracking-[0.2em] text-white/70 uppercase">Sektion</span>
          <p class="mt-4 text-[clamp(24px,4vw,40px)] leading-[0.9] font-black tracking-[-0.035em] uppercase">
            Bricht aus
          </p>
          <span
            aria-hidden="true"
            class="pointer-events-none absolute top-0 -left-12 text-[9px] font-semibold tracking-[0.18em] text-white/40 uppercase"
            >&larr; viewport</span
          >
          <span
            aria-hidden="true"
            class="pointer-events-none absolute top-0 -right-12 text-[9px] font-semibold tracking-[0.18em] text-white/40 uppercase"
            >viewport &rarr;</span
          >
        </div>
        <p class="mt-3 max-w-[56ch] text-[13px] leading-[1.6] opacity-60">
          Utility <code class="font-mono text-[11px]">section-full-bleed-clay</code> in
          <code class="font-mono text-[11px]">global.css</code> — via
          <code class="font-mono text-[11px]">box-shadow: 0 0 0 100vmax</code> +
          <code class="font-mono text-[11px]">clip-path: inset(0 -100vmax)</code>. Die Sektion bleibt im Grid, das
          Shadow malt Clay bis zum Viewport-Rand. Sparsam einsetzen — eine Farb-Zäsur pro Seite genügt.
        </p>
      </div>
    </section>

    <!-- Footer -->
    <footer
      class="mt-[72px] flex flex-wrap items-center justify-between gap-2 border-t border-navy pt-9 text-[11px] font-semibold tracking-[0.18em] uppercase opacity-40"
    >
      <span>Brand Guide · Matchday Winsen 2026</span>
      <span>TV Winsen/Luhe · Seit 1913</span>
    </footer>
  </main>
</Layout>

<style is:global>
  .sect:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  /* Hero entrance */
  .enter {
    animation: enterUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .enter--1 {
    animation-delay: 0.1s;
  }
  .enter--2 {
    animation-delay: 0.2s;
  }
  .enter--3 {
    animation-delay: 0.35s;
  }
  .enter--4 {
    animation-delay: 0.55s;
  }

  @keyframes enterUp {
    from {
      opacity: 0;
      transform: translateY(2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll reveal */
  .reveal {
    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 0% entry 12%;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Composition stagger */
  .stagger {
    animation: staggerIn linear both;
    animation-timeline: view();
    animation-range: entry 0% entry 20%;
  }
  .stagger--1 {
    animation-delay: 0s;
  }
  .stagger--2 {
    animation-delay: 0.08s;
  }
  .stagger--3 {
    animation-delay: 0.16s;
  }
  .stagger--4 {
    animation-delay: 0.24s;
  }

  @keyframes staggerIn {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
